    "import re\n",
    "import string\n",
    "\n",
    "# Text saaf karne ka function\n",
    "def clean_text(text):\n",
    "    text = text.lower() # Sab kuch chote letters mein convert karega\n",
    "    text = re.sub('\\[.*?\\]', '', text) # Brackets hatayega\n",
    "    text = re.sub('\\\\W', \" \", text) # Faltu symbols hatayega\n",
    "    text = re.sub('https?://\\S+|www\\.\\S+', '', text) # Links hatayega\n",
    "    text = re.sub('<.*?>+', '', text) # HTML tags hatayega\n",
    "    text = re.sub('[%s]' % re.escape(string.punctuation), '', text) # Punctuation hatayega\n",
    "    text = re.sub('\\n', '', text) # New lines hatayega\n",
    "    return text\n",
    "\n",
    "# Ab is function ko poore data par apply kar dete hain\n",
    "df['text'] = df['text'].apply(clean_text)\n",
    "\n",
    "print(\"Waah! Data ki saaf-safai poori ho gayi.\")\n",
    "print(df.head(3))"
   ]
