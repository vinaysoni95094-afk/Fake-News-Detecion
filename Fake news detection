    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import accuracy_score\n",
    "\n",
    "# 1. Data ko Train aur Test set mein baant rahe hain (80% seekhne ke liye, 20% test ke liye)\n",
    "x_train, x_test, y_train, y_test = train_test_split(df['text'], df['target'], test_size=0.2, random_state=42)\n",
    "\n",
    "# 2. Words ko Numbers mein badal rahe hain (Vectorization)\n",
    "vectorizer = TfidfVectorizer()\n",
    "xv_train = vectorizer.fit_transform(x_train)\n",
    "xv_test = vectorizer.transform(x_test)\n",
    "\n",
    "# 3. Model ko train kar rahe hain (Logistic Regression algorithm se)\n",
    "model = LogisticRegression()\n",
    "model.fit(xv_train, y_train)\n",
    "\n",
    "# 4. Accuracy check kar rahe hain ki computer kitna sahi seekha\n",
    "predictions = model.predict(xv_test)\n",
    "score = accuracy_score(y_test, predictions)\n",
    "\n",
    "print(\"Mubarak ho! Model training poori ho gayi.\")\n",
    "print(\"Model ki Accuracy kitni aayi:\", score * 100, \"%\")"
   ]
  },
